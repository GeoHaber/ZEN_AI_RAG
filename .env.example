# ZenAI Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# API AUTHENTICATION (Optional - enables auth for external requests)
# =============================================================================
# If set, external requests to the Hub API require this key in X-API-Key header
# Localhost requests always pass (for UI integration)
ZENAI_API_KEY=

# =============================================================================
# EXTERNAL LLM API KEYS (Optional - for Multi-LLM Consensus feature)
# =============================================================================

# Anthropic (Claude)
ZENAI_ANTHROPIC_API_KEY=
ZENAI_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google (Gemini)
ZENAI_GOOGLE_API_KEY=
ZENAI_GOOGLE_MODEL=gemini-pro

# xAI (Grok)
ZENAI_XAI_API_KEY=
ZENAI_XAI_MODEL=grok-beta

# =============================================================================
# MESSAGING INTEGRATIONS (Optional)
# =============================================================================

# Telegram Bot
ZENAI_TELEGRAM_TOKEN=
# Comma-separated list of allowed user IDs
ZENAI_TELEGRAM_WHITELIST=

# WhatsApp (E.164 format phone numbers, comma-separated)
ZENAI_WHATSAPP_WHITELIST=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Ports (defaults shown)
ZENAI_UI_PORT=8080
ZENAI_LLM_PORT=8001
ZENAI_MGMT_PORT=8002
ZENAI_VOICE_PORT=8003

# Model directory (optional - uses auto-discovery by default)
ZENAI_MODEL_DIR=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable swarm mode for parallel processing
ZENAI_SWARM_ENABLED=false
ZENAI_SWARM_SIZE=3
